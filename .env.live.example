MAKERSHELF_PORT=3000
MAKERSHELF_APP_NAME=makershelf
MAKERSHELF_PRODUCT_PROFILE=server
DATABASE_PROVIDER=postgresql
MAKERSHELF_DEPLOYMENT_MODE=docker-team
MAKERSHELF_DATA_BACKEND=postgres
MAKERSHELF_STORAGE_DRIVER=filesystem
MAKERSHELF_STORAGE_ROOT=/data/storage
MAKERSHELF_ENABLE_EXPERIMENTAL_WEBSITE_IMPORT=true
MAKERSHELF_AUTH_SECRET=replace-with-a-long-random-secret

POSTGRES_DB=makershelf
POSTGRES_USER=makershelf
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgres://makershelf:change-this-strong-password@postgres:5432/makershelf
MAKERSHELF_LICENSE_TIER=community
MAKERSHELF_LICENSE_KEY=MAKERSHELF-COMMUNITY-live
MAKERSHELF_LICENSE_SERVER_URL=
MAKERSHELF_LICENSE_LAST_CHECK=
MAKERSHELF_INSTANCE_ID=

MAKERSHELF_BOOTSTRAP_EMAIL=admin@example.com
MAKERSHELF_BOOTSTRAP_PASSWORD=ChangeThisAdminPassword!
